# ==========================================
# ☕ Spring Boot (Java) Backend
# ==========================================

# Target build directories
**/target/
**/build/
**/out/

# IDE specific files
**/.idea/
**/.classpath
**/.project
**/.settings/
**/*.iml
**/*.ipr
**/*.iws
**/.nbworkspace/
**/.nbhint/

# Log files
**/logs/
**/*.log

# Crash logs
**/hs_err_pid*
**/replay_pid*

# Build system wrappers
# (Uncomment the lines below if you do not want to commit Maven/Gradle wrappers)
# **/.mvn/
# **/mvnw
# **/mvnw.cmd
# **/.gradle/
# **/gradlew
# **/gradlew.bat

# ==========================================
# ⚛️ React Frontend
# ==========================================

# Dependencies
**/node_modules/
**/.pnp/
**/.pnp.js

# Production build outputs
**/dist/
**/build/

# Testing
**/coverage/

# Local env files (contain sensitive API keys/secrets)
**/.env
**/.env.local
**/.env.development.local
**/.env.test.local
**/.env.production.local

# Debug logs
**/*.log*
**/npm-debug.log*
**/yarn-debug.log*
**/yarn-error.log*
**/pnpm-debug.log*

# Editor/IDE configs
**/.vscode/
**/.eslintcache
**/.stylelintcache

# ==========================================
# 🖥️ Operating System Specific
# ==========================================
.DS_Store
Thumbs.db
